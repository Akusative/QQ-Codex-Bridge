# NapCat OneBot v11 HTTP，仅监听本机
ONEBOT_HTTP_URL=http://127.0.0.1:3000

# Bridge 接收 NapCat 反向 WebSocket
BRIDGE_WS_HOST=127.0.0.1
BRIDGE_WS_PORT=3001
BRIDGE_WS_PATH=/onebot/v11

# 与 NapCat HTTP Server、WebSocket Client 完全一致；不要提交真实值
ONEBOT_ACCESS_TOKEN=replace_with_private_token

# 允许向机器人发指令的 QQ 号；不要提交真实值
ALLOWED_QQ_USER_ID=123456789

AGENT_MODE=mock
CODEX_COMMAND=codex
CODEX_WORKDIR=F:\AI\codex-workspace
ALLOWED_WORKSPACE_ROOT=F:\AI

# 留空表示记忆只保存在本地 Git 仓库；需要时再填写不含凭证的私有远端地址
MEMORY_REMOTE_URL=

# 向量记忆检索（硅基流动免费 embedding）。留空 SILICONFLOW_API_KEY 则关闭向量、回退关键词检索。
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
MEMORY_EMBED_MODEL=BAAI/bge-m3
# 混合检索里向量占比（其余给 BM25 关键词）；命中阈值（低于则不选用）
MEMORY_VECTOR_WEIGHT=0.85
MEMORY_RELEVANCE_THRESHOLD=0.3

LOG_LEVEL=info
TASK_TIMEOUT_SECONDS=600
QQ_MESSAGE_CHUNK_SIZE=1500
# 普通回复每条 QQ 消息最多包含几句话；代码块和指令列表保持完整
ALLOW_HIGH_RISK_COMMANDS=false

# WebUI 本机免密管理；首次密码在本机创建，之后远程管理员可改密码、更新和重启
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
# 默认拒绝公网来源；仅在云安全组已按来源 IPv4 限制端口后改为 true
WEBUI_ALLOW_PUBLIC_ACCESS=false
WEBUI_PORT=3080
WEBUI_SESSION_HOURS=720
WEBUI_PAIRING_MINUTES=10
