{
  "name": "qq-codex-bridge",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "tsx scripts/check-env.ts",
    "push": "tsx scripts/push-message.ts",
    "push:file": "tsx scripts/push-file.ts",
    "test": "vitest run",
    "package:update": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/build-update-package.ps1"
  },
  "dependencies": {
    "dotenv": "^17.0.0",
    "pino": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
